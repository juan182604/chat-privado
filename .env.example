# =====================================================
# Chat Privado — Variables de entorno
# =====================================================
# Copia este archivo a .env y completa los valores.
# En desarrollo local solo necesitas DATABASE_URL.
# En producción (Render) necesitas TODAS las variables.

# ===== BASE DE DATOS (Turso) =====
# Desarrollo local (SQLite):
# DATABASE_URL=file:./db/custom.db
#
# Producción (Turso):
DATABASE_URL=libsql://TU-BASE.turso.io
DATABASE_AUTH_TOKEN=TU-TOKEN-AQUI

# ===== CLOUDFLARE R2 (fotos y audios) =====
# Solo necesario en producción. En desarrollo se usa disco local.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chat-privado-uploads
# R2_ENDPOINT se calcula automáticamente si tienes R2_ACCOUNT_ID

# ===== APLICACIÓN =====
NODE_ENV=development
# NEXTAUTH_SECRET=genera-uno-aleatorio-largo
